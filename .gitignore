
# Local Docker Compose overrides (merged with compose.yaml by docker compose)
compose.override.yaml
compose.override.yml

# Dependencies
node_modules/
yarn.lock

# Build output
dist/
# OpenL docs bundle fetched at build time by dist/fetch-guides.js — never committed
