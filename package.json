{
  "name": "openl-mcp-server",
  "version": "0.0.4",
  "description": "MCP Server for OpenL Studio Rules Management System",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openl-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "LICENSE",
    "README.md",
    "README.cli.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openl-tablets/openl-mcp.git"
  },
  "homepage": "https://github.com/openl-tablets/openl-mcp#readme",
  "bugs": {
    "url": "https://github.com/openl-tablets/openl-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/server.js",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && node dist/server.js",
    "watch": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/integration",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "mcp",
    "openl-studio",
    "rules-engine",
    "brms"
  ],
  "author": "",
  "license": "LGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "ws": "^8.21.0",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.18.2",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^10.4.1",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
