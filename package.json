{
  "name": "openl-mcp",
  "version": "0.0.1",
  "description": "MCP Server for OpenL Studio 6.3.0 Rules Management System",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openl-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "guides/",
    "prompts/",
    "LICENSE",
    "README.md",
    "README.cli.md"
  ],
  "openlDocs": {
    "repo": "openl-tablets/openl-tablets",
    "ref": "6.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openl-tablets/openl-mcp.git"
  },
  "homepage": "https://github.com/openl-tablets/openl-mcp#readme",
  "bugs": {
    "url": "https://github.com/openl-tablets/openl-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc && node dist/fetch-guides.js",
    "fetch:guides": "tsc && node dist/fetch-guides.js --force",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "npm run build && node dist/index.js",
    "dev:http": "npm run build && node dist/index.js --http",
    "watch": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/integration",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "mcp",
    "openl-studio",
    "rules-engine",
    "brms"
  ],
  "author": "",
  "license": "LGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "nock": "^14.0.15",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
