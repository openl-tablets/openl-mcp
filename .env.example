# OpenL MCP Server Configuration

# OpenL Studio Base URL (or pass it as the positional argument: `openl-mcp-server <url>`)
# Use http://localhost:8080 when running with npx on the host.
# Use http://host.docker.internal:8080 when the server itself runs in a Docker container.
OPENL_BASE_URL=http://localhost:8080

# ============================================================================
# Authentication Configuration
# ============================================================================

# Personal Access Token (PAT) — the only supported credential.
# Create one in OpenL Studio: User Settings → Personal Access Tokens.
# Leave unset to run against an OpenL Studio in single-user mode, which accepts
# unauthenticated requests.
OPENL_PERSONAL_ACCESS_TOKEN=openl_pat_your-token-here

# ============================================================================
# Additional Configuration
# ============================================================================

# Request Timeout (optional, in milliseconds)
# Default: 30000 (30 seconds)
# OPENL_TIMEOUT=30000

# Client Document ID (optional) - sent as Client-Document-Id header on all API requests for audit and debugging
# OPENL_CLIENT_DOCUMENT_ID=your-document-or-session-id

# ============================================================================
# Notes
# ============================================================================
# - Authentication uses a Personal Access Token (OPENL_PERSONAL_ACCESS_TOKEN),
#   or no credentials at all for single-user mode.
# - For production, always use HTTPS URLs
# - Never commit this file with real credentials
# - Copy this file to .env and update with your actual values
